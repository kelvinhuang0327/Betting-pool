<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.bettingpool.orchestrator.copilot-daemon</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_ROOT__/scripts/launchd/run_copilot_daemon.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__PROJECT_ROOT__</string>

    <!-- LaunchAgent (非 LaunchDaemon)：在使用者 GUI session 中執行，確保可存取 macOS keychain -->
    <!-- 預設關閉：需手動執行 scheduler_start.sh 才會啟動 -->
    <key>RunAtLoad</key>
    <false/>

    <key>KeepAlive</key>
    <false/>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>__USER_HOME__</string>
        <key>PATH</key>
        <string>__LAUNCH_PATH__</string>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
        <!-- gh auth 的 token 位置 -->
        <key>GH_CONFIG_DIR</key>
        <string>__USER_HOME__/.config/gh</string>
    </dict>

    <key>StandardOutPath</key>
    <string>__PROJECT_ROOT__/runtime/agent_orchestrator/logs/launchd/copilot_daemon.launchd.out.log</string>

    <key>StandardErrorPath</key>
    <string>__PROJECT_ROOT__/runtime/agent_orchestrator/logs/launchd/copilot_daemon.launchd.err.log</string>

    <!-- crash 後 10 秒重啟 -->
    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
