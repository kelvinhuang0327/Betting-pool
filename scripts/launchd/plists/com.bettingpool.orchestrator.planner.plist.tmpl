<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.bettingpool.orchestrator.planner</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_ROOT__/scripts/launchd/run_planner_tick.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__PROJECT_ROOT__</string>

    <!-- 預設關閉：需手動執行 scheduler_start.sh 才會啟動 -->
    <key>RunAtLoad</key>
    <false/>

    <key>StartInterval</key>
    <integer>600</integer>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>__LAUNCH_PATH__</string>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
    </dict>

    <key>StandardOutPath</key>
    <string>__PROJECT_ROOT__/runtime/agent_orchestrator/logs/launchd/planner_launchd.out.log</string>

    <key>StandardErrorPath</key>
    <string>__PROJECT_ROOT__/runtime/agent_orchestrator/logs/launchd/planner_launchd.err.log</string>
</dict>
</plist>
